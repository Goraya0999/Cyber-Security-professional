# =========================================================
# DIDS — Required Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!
# =========================================================

# ------ Backend (api-server) ------

# REQUIRED: Port for the Express server
PORT=3001

# REQUIRED: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/dids

# REQUIRED: Secret key for JWT signing (min 32 chars, random)
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# OPTIONAL: API key to protect the POST /scan endpoint
# Leave empty to disable API key protection (dev mode)
DIDS_API_KEY=

# OPTIONAL: Express gateway -> FastAPI ML service integration
# In Docker Compose this points at the ml-api service.
DIDS_ML_API_URL=http://localhost:8000
DIDS_ML_API_KEY=change-me-internal-service-key
DIDS_ML_TIMEOUT_MS=2500

# REQUIRED when running the FastAPI ML service as an internal service.
DIDS_INTERNAL_API_KEY=change-me-internal-service-key

# OPTIONAL: Maximum upload size for network traffic analysis files
# Default: 262144000 bytes (250 MB)
DIDS_ANALYSIS_MAX_UPLOAD_BYTES=262144000

# OPTIONAL: Live traffic scanner write protection
# Limits how many request log rows one IP can create per minute.
DIDS_LIVE_TRAFFIC_MAX_LOGS_PER_IP_PER_MINUTE=600

# ------ Frontend (dids-dashboard) ------

# REQUIRED: Port for the Vite dev server
PORT=5173

# REQUIRED: Base path for the app (usually /)
BASE_PATH=/

# ------ Production overrides ------
# NODE_ENV=production
